NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile, hCaptcha, or your CAPTCHA provider.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: VAPID keys for web push.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Keep this random and private in production.
AUDIT_LOG_SECRET=

# Optional separate key for encrypting user app data at rest.
# If empty, AUDIT_LOG_SECRET is used. Use at least 32 random characters in production.
APP_DATA_ENCRYPTION_KEY=
